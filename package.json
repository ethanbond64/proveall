{
  "name": "proveall",
  "version": "0.0.0",
  "description": "ProveAll - Code review and verification tool",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "tauri:icon": "tauri icon",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "start": "electron .",
    "dist": "npm run build:renderer && electron-builder",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:win": "npm run build:renderer && electron-builder --win",
    "dist:linux": "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId": "com.proveall",
    "productName": "ProveAll",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "src/renderer/dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "drizzle-kit": "^0.31.8",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "drizzle-orm": "^0.45.1",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.30.0",
    "sql.js": "^1.12.0",
    "zustand": "^5.0.11"
  }
}
