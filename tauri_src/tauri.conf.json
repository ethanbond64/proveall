{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/refs/heads/main/crates/tauri-utils/schema.json",
  "productName": "ProveAll",
  "version": "0.4.1",
  "identifier": "com.proveall",
  "build": {
    "frontendDist": "../src/renderer/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ProveAll",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ethanbond64/proveall/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_UNTIL_KEY_IS_GENERATED"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Ethan Bond (GYPQ65867V)"
    }
  }
}
